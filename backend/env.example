SERVICE_ID=tauron
SERVICE_NAME=Tauron

DEBUG=false
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

RATE_LIMIT_MAX_ATTEMPTS=100
RATE_LIMIT_WINDOW_HOURS=1

CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=tauron

POSTGRES_SSL=false
POSTGRES_CONNECT_TIMEOUT=10

POSTGRES_AUTO_CREATE_DATABASE=true
POSTGRES_MAINTENANCE_DATABASE=postgres

DATABASE_URL_OVERRIDE=

DATABASE_SCHEMA=tauron
BOOTSTRAP_DATABASE_ON_STARTUP=true
